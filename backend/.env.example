# 复制为 .env 后按需修改（不要提交真实密钥）

# development | production
APP_ENV=development

# 生产必须改成随机长串（≥32 字符），例如：
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=yangmind-dev-secret-change-me-before-production

# 本地 Docker Postgres（见仓库根目录 docker-compose.yml）
DATABASE_URL=postgresql+psycopg://yangmind:yangmind@127.0.0.1:5432/yangmind
# 仍可用 SQLite 做临时调试：
# DATABASE_URL=sqlite:///./yangmind.db

# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 唯一管理员（登录可用别名 admin）
# SEED_ADMIN_EMAIL=admin@yangmind.cn
# SEED_ADMIN_PASSWORD=1234asdF
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_NICKNAME=管理员
